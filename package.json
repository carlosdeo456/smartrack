{
  "name": "smartrack",
  "version": "1.0.0",
  "private": true,
  "description": "SmartTrack - Intercity Parcel Tracking System",
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm start --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm start --prefix frontend",
    "db:setup": "npm run db:setup --prefix backend",
    "db:setup:win": "npm run db:setup --prefix backend",
    "migrate": "npm run migrate --prefix backend",
    "migrate:devices": "npm run migrate:devices --prefix backend",
    "seed": "npm run seed --prefix backend",
    "seed:users": "npm run seed:users --prefix backend",
    "seed:gps": "npm run seed:gps --prefix backend",
    "seed:tanzania": "npm run seed:tanzania --prefix backend",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "deploy:firebase": "npm run build:frontend && npx firebase deploy --only hosting"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "firebase-tools": "^14.0.0"
  },
  "engines": {
    "node": ">=16"
  }
}
