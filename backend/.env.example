# =============================================================================
# SmartTrack / Decoupled API — Backend Environment Template
# Copy to backend/.env and adjust for your machine + network.
# =============================================================================

# --- Server (bind on all interfaces so LAN clients can connect) ---
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# --- Database (PostgreSQL connection pool) ---
DATABASE_URL=postgresql://postgres:smartrack123@localhost:5432/smartrack

# --- CORS: allow React dev server + other machines on Wi-Fi ---
# Add your PC's LAN IP where React runs, e.g. http://192.168.1.10:3000
CORS_ORIGIN=http://localhost:3000
# Add Firebase Hosting URL after deploy, e.g. https://smartrack-app.web.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://smartrack-uxeb.vercel.app
# Set true for LAN dev when Flutter/React run on other PCs (never use in production)
CORS_ALLOW_ALL=true

# --- Auth (SmartTrack domain routes) ---
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d
IOT_API_KEY=
ENABLE_SIMULATED_GPS=false

# --- Optional integrations ---
GOOGLE_MAPS_API_KEY=your-api-key-here
SMS_PROVIDER=twilio
SMS_SENDER_ID=SmartTrack
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
RAFIKI_SMS_BASE_URL=https://api.rafikisms.com/v1/vendor/send-sms
RAFIKI_SMS_API_KEY=
ENABLE_WHATSAPP_NOTIFICATIONS=false
DEFAULT_SMS_COUNTRY=TZ
SMARTTRACK_CARRIER_NAME=SmartTrack
NOTIFICATION_MAX_RETRIES=3
SHIPMENT_CHAT_TOKEN_EXPIRE=7d

# --- Production example (cloud) ---
# NODE_ENV=production
# HOST=0.0.0.0
# DATABASE_URL=postgresql://user:pass@db.example.com:5432/smartrack
# CORS_ORIGINS=https://app.yourdomain.com
# CORS_ORIGIN=https://app.yourdomain.com
