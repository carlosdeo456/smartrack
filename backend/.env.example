PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/smartrack
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d
CORS_ORIGIN=http://localhost:3000

# IoT Configuration
MQTT_BROKER=mqtt://broker.hivemq.com:1883
MQTT_TOPIC=smartrack/sensors

# Google Maps API (geocoding + road routes; falls back to OpenStreetMap/OSRM)
GOOGLE_MAPS_API_KEY=your-api-key-here

# Twilio SMS (optional — logs to console when not set)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Redis (Optional for caching)
REDIS_URL=redis://localhost:6379
